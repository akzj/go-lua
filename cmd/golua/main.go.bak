package main

import (
	"flag"
	"fmt"
	"os"

	"github.com/akzj/go-lua/internal/lapi"
	"github.com/akzj/go-lua/internal/lobject"
	"github.com/akzj/go-lua/internal/lua"
)

func main() {
	flag.Parse()
	args := flag.Args()

	L := lapi.Lua_newstate(nil, nil, 0)
	if L == nil {
		fmt.Fprintln(os.Stderr, "Error: failed to create Lua state")
		os.Exit(1)
	}

	defer func() {
		if r := recover(); r != nil {
			fmt.Fprintf(os.Stderr, "Panic: %v\n", r)
			lapi.Lua_close(L)
			os.Exit(1)
		}
	}()

	lua.OpenAll(L)

	if len(args) == 0 {
		fmt.Println("Go Lua 5.5 - A Lua interpreter written in Go")
		fmt.Println("Usage: golua [script.lua] [args...]")
		lapi.Lua_close(L)
		os.Exit(0)
	}

	filename := args[0]
	data, err := os.ReadFile(filename)
	if err != nil {
		fmt.Fprintf(os.Stderr, "Error: cannot read %s: %v\n", filename, err)
		lapi.Lua_close(L)
		os.Exit(1)
	}

	// Load chunk
	errcode := lapi.Lua_load(L, nil, string(data), filename, "t")
	if errcode != 0 {
		var l int
		msg := lapi.Lua_tolstring(L, -1, &l)
		fmt.Fprintf(os.Stderr, "Syntax error: %s\n", msg)
		lapi.Lua_close(L)
		os.Exit(1)
	}

	// Execute
	errcode = lapi.Lua_pcall(L, 0, -1, 0)
	if errcode != 0 {
		if lapi.Lua_type(L, -1) == lobject.LUA_TSTRING {
			var l int
			msg := lapi.Lua_tolstring(L, -1, &l)
			fmt.Fprintf(os.Stderr, "Error: %s\n", msg)
		} else {
			fmt.Fprintf(os.Stderr, "Runtime error code: %d\n", errcode)
		}
		lapi.Lua_close(L)
		os.Exit(1)
	}

	lapi.Lua_close(L)
}
